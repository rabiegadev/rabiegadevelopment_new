# PostgreSQL (Neon, Supabase, lokalnie: postgresql://user:pass@localhost:5432/rabiega)
DATABASE_URL=

# Wygeneruj: openssl rand -base64 32
AUTH_SECRET=

# Publiczny URL aplikacji (produkcja: https://rabiegadevelopment.pl)
NEXTAUTH_URL=http://localhost:3000

# E-mail do powiadomień o formularzu
ADMIN_EMAIL=

# Resend — https://resend.com (opcjonalnie; bez tego zapytania zapisują się bez maili)
RESEND_API_KEY=
# Nadawca zweryfikowany w Resend (domena lub onboarding@resend.dev na testy)
RESEND_FROM="Rabiega Development <onboarding@resend.dev>"

# Seed pierwszego admina (npm run db:seed)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME="Administrator"
