# PostgreSQL (Neon, Supabase, lokalnie: postgresql://user:pass@localhost:5432/rabiega)
DATABASE_URL=

# Wygeneruj: openssl rand -base64 32
AUTH_SECRET=

# Kanoniczny publiczny URL (Auth.js). Lokalnie: poniżej. Na Vercelu: https://twoja-domena.pl lub https://projekt.vercel.app (bez localhost).
NEXTAUTH_URL=http://localhost:3000

# E-mail do powiadomień o formularzu
ADMIN_EMAIL=

# Resend — https://resend.com (opcjonalnie; bez tego zapytania zapisują się bez maili)
RESEND_API_KEY=
# Nadawca zweryfikowany w Resend (domena lub onboarding@resend.dev na testy)
RESEND_FROM="Rabiega Development <onboarding@resend.dev>"

# Seed pierwszego admina (npm run db:seed)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME="Administrator"

# Publiczne dane na stronie /kontakt (opcjonalnie nadpisują domyślne z src/config/contact.ts)
# NEXT_PUBLIC_CONTACT_CITY=
# NEXT_PUBLIC_CONTACT_ADDRESS=
# NEXT_PUBLIC_CONTACT_PHONES="+48 123 456 789"
# NEXT_PUBLIC_CONTACT_EMAILS="kontakt@example.com"
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/...
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/...
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/...
# NEXT_PUBLIC_SOCIAL_LINKEDIN=
